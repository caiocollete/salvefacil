# Monorepo — o que não deve ir para o repositório

# --- Variáveis de ambiente (manter *.example versionados) ---
.env
.env.*
!.env.example
!**/.env.example

# --- Dependências ---
node_modules/

# --- API (Nest) ---
api/dist/
api/coverage/
api/generated/

# --- Web (Next.js) ---
web/.next/
web/out/
web/.turbo

# --- Cache / artefatos de build ---
.turbo
*.tsbuildinfo
.eslintcache
.cache/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testes & cobertura ---
coverage/
.nyc_output/
junit.xml

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# --- Sistema operacional ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Chaves e certificados locais ---
*.pem
*.key

# --- Pacotes / temporários ---
*.tgz
*.pid
*.seed
*.pid.lock

# --- Ferramentas opcionais ---
.vercel
.parcel-cache

# --- Playwright / E2E (se passar a usar) ---
playwright-report/
test-results/
blob-report/
